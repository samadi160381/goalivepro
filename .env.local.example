# Copy this file to .env.local and fill in your real key.
# Get a free key (100 requests/day, no credit card) at:
# https://dashboard.api-football.com/register
#
# After registering, find your key on the dashboard under
# "API Keys" / Profile. It looks like a long hex string.

API_FOOTBALL_KEY=your_key_here

# Optional: override the default league/season the app shows on load.
# Premier League = 39, Champions League = 2, World Cup = 1
NEXT_PUBLIC_DEFAULT_LEAGUE_ID=39
NEXT_PUBLIC_DEFAULT_SEASON=2025
